{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@/app/about/*": ["./src/app/(frontend)/about/*"],
      "@/app/blog/*": ["./src/app/(frontend)/blog/*"],
      "@/app/career/*": ["./src/app/(frontend)/career/*"],
      "@/app/industries/*": ["./src/app/(frontend)/industries/*"],
      "@/app/schedule/*": ["./src/app/(frontend)/schedule/*"],
      "@/app/services/*": ["./src/app/(frontend)/services/*"],
      "@payload-config": ["./src/payload.config.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
